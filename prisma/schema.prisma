// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// prisma/schema.prisma
// Define your database models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql" // atau postgresql
  url      = env("DATABASE_URL")
}

model user {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  brand    String
  vehicles vehicle[]
}

model vehicle {
  id       Int    @id @default(autoincrement())
  car_name String
  brand    String
  type     String
  category String
  fuel     String?
  colors   String?
  price    Int?
  topSpeed Int
  image    String?
  authorId Int?
  user     user?  @relation(fields: [authorId], references: [id])
}

model maps {
  place_id          Int    @id @default(autoincrement())
  place_name        String
  place_category    String
  place_image       String
  place_desc        String?
  location          String
  uses              String?
  location_ref      String?
  location_link_ref String? @db.Text
  place_int         Json
  place_ext         Json
}
