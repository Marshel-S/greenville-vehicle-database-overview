// prisma/schema.prisma
// Define your database models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model user {
  id       String       @id @default(uuid())
  email    String    @unique
  password String
  brand    String
  vehicles vehicle[]
}

model vehicle {
  id       String       @id @default(uuid())
  car_name String
  brand    String
  type     String
  category String
  fuel     String?
  colors   String?
  price    Int?
  topSpeed Int
  image    String
  authorId String?
  user     user?   @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model maps {
  place_id          String       @id @default(uuid())
  place_name        String
  place_category    String
  place_image       String
  place_desc        String?
  location          String
  uses              String?
  location_ref      String?
  location_link_ref String?       @db.NVarChar(Max)
  place_int         String?
  place_ext         String?
  category          mapsCategory? @relation(fields: [place_category], references: [place_category])
}

model mapsCategory {
  place_category_id   String       @id @default(uuid())
  place_category      String @unique
  place_category_desc String?
  maps                maps[]
}